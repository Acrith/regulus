DISCORD_TOKEN=your-bot-token-goes-here

# Comma-separated pairs of guild_id:mod_channel_id.
# Every server the bot should operate in must be listed here.
# Guilds the bot is a member of but that are not listed here are ignored
# (no command sync, no join audits posted).
#
# Single server:   GUILDS=1234567890:9876543210
# Multiple:        GUILDS=1234567890:9876543210,2222222222:3333333333
GUILDS=your-guild-id:your-mod-channel-id

# Optional. Path to the SQLite database file. Defaults to regulus.db
# alongside bot.py. Override if you want the file somewhere else.
# DB_PATH=/var/lib/regulus/regulus.db
